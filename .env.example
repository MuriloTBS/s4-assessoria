# Vercel Environment Variables — configure no dashboard da Vercel
# Nunca faça commit de valores reais neste arquivo

# Oracle ORDS (backend)
ORDS_BASE_URL=https://<seu-id>.adb.<regiao>.oraclecloudapps.com/ords/admin

# Segurança
AUTH_PEPPER=gere_com_openssl_rand_hex_32
RESET_SECRET=gere_com_openssl_rand_hex_32
INTERNAL_API_KEY=gere_com_openssl_rand_hex_32

# Email (Resend — resend.com)
RESEND_API_KEY=re_sua_chave_aqui

# Frontend Vite (deve ser igual ao INTERNAL_API_KEY)
VITE_INTERNAL_API_KEY=gere_com_openssl_rand_hex_32

# Sentry (DSN disponível em Settings > Client Keys no dashboard do Sentry)
VITE_SENTRY_DSN=https://<dsn>@<org>.ingest.us.sentry.io/<project-id>
SENTRY_AUTH_TOKEN=sntrys_sua_chave_aqui
